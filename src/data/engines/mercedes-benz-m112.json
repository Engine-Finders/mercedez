          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "How much does an M112 engine replacement cost?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "A reconditioned M112 typically costs £1,200–£2,200 supply only, varying by displacement and specific variant. Fitting adds £800–£1,200 depending on labour rates. Use our calculator for a figure specific to your car."
              }
            },
            {
              "@type": "Question",
              "name": "Is the Mercedes M112 a reliable engine?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes — the M112 is widely regarded as one of Mercedes' most durable V6 engines, rated 4.0★ out of 5. It suffers few major failures, and most issues are cheap, well-understood repairs."
              }
            },
            {
              "@type": "Question",
              "name": "What is the most common M112 failure?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "The most common failure is the crank pulley rubber disintegrating — a cheap, straightforward fix. Oil leaks from valve cover breathers (PCV system) are also reported."
              }
            },
            {
              "@type": "Question",
              "name": "Which Mercedes models use the M112?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "The M112 powered a wide range of Mercedes models including the C-Class (W202/W203), E-Class (W210/W211), S-Class (W220), CLK, SLK, M-Class, G-Class, and Viano/Vito, plus the Chrysler Crossfire."
              }
            },
            {
              "@type": "Question",
              "name": "How long does the M112 last?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "With proper maintenance — regular oil changes and crank pulley inspections — the M112 is capable of 200,000+ miles. It is considered significantly more durable than its M272 successor."
              }
            }
          ]
