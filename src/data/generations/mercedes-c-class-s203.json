  "overview": {
    "h2": "Mercedes C‑Class S203 — Overview",
    "intro": "The S203 is the estate body of Mercedes‑Benz's second‑generation C‑Class, arriving in 2001 as the successor to the S202. It introduced the 'four‑eyed' twin‑headlight design language, a longer wheelbase, and a more extensive standard equipment list than its rivals. A significant 2004 facelift brought revised styling, new engine families (M271 petrol, OM646/OM648 diesel), and the arrival of the C 55 AMG V8. The S203 shares its platform and engines with the W203 saloon but offers up to 1,500 litres of load space.",
    "keyFacts": "Platform: W203 (Mercedes‑Benz second‑generation C‑Class platform) • Predecessor: S202 (first‑generation C‑Class estate) • Successor: S204 (third‑generation C‑Class estate) • Sibling body styles in this generation: W203 (saloon), CL203 (SportCoupé)",
    "marketIntelligenceLine": "The S203 estate generated significant UK engine enquiry demand in 2025 [MB‑VERIFIED], concentrated on the OM611/OM646 diesel and M271 supercharged petrol variants as these cars enter their third decade of service."
  },
  "bestWorstEngines": {
    "items": [
      {
        "slot": "Best Diesel Overall",
        "engine": "OM646 (C 220 CDI, facelift, 2004–2007)",
        "quote": "“The facelift OM646 improved on the OM611 with better injector design and common‑rail refinement. 150 PS and 340 Nm of torque deliver effortless estate‑car performance with genuine 200,000+ mile potential.” Who it’s for: Buyers who want a proven, efficient diesel estate without the 5‑cylinder’s higher running costs.",
        "whoItsFor": ""
      },
      {
        "slot": "Best Petrol Overall",
        "engine": "M112 V6 (C 240 / C 320)",
        "quote": "“The M112 V6 is the S203's most robust petrol engine — smooth, torquey, and free of the M271's camshaft adjuster issues and the M272's balance shaft concerns. The 218 PS C 320 is the sweet spot.” Who it’s for: Buyers who want V6 refinement without AMG running costs.",
        "whoItsFor": ""
      },
      {
        "slot": "Highest Risk",
        "engine": "M272 V6 (C 230 / C 350, 2005–2007)",
        "quote": "“The M272's balance shaft sprocket wear is this generation's defining risk — a design flaw that can lead to catastrophic engine failure. Mercedes acknowledged the issue but didn't extend the warranty as widely as with the M260.” Who it’s for: Buyers who understand the risk and have documented balance shaft history.",
        "whoItsFor": ""
      },
      {
        "slot": "Most Expensive Failure",
        "engine": "C 55 AMG (M113 V8)",
        "quote": "“The 367 PS 5.4‑litre V8 is a joy to drive but punishing to repair — valve cover gaskets, timing chain tensioners, and the entire engine bay's heat‑related wear add up fast. A full replacement runs well into five figures.” Who it’s for: AMG enthusiasts with deep pockets and full service history.",
        "whoItsFor": ""
      },
      {
        "slot": "Best Value",
        "engine": "OM611 (C 220 CDI, pre‑facelift, 2001–2004)",
        "quote": "“The older OM611 is cheaper to buy and cheaper to replace than the facelift OM646 — and with injector seal maintenance, it's equally durable. 143 PS and 340 Nm are plenty for estate duties.” Who it’s for: Buyers who want diesel economy on a tighter budget.",
        "whoItsFor": ""
      },
      {
        "slot": "Most Overlooked",
        "engine": "M112 V6 (C 240, pre‑facelift)",
        "quote": "“The 170 PS C 240 is often dismissed in favour of the C 320, but it shares the same robust M112 V6 architecture with lower running costs — and none of the M272's balance shaft anxiety.” Who it’s for: Buyers who want V6 ownership without the V8 tax.",
        "whoItsFor": ""
      }
    ]
  },
